# DeepSeek API（主模型）
DEEPSEEK_API_KEY=sk-your-key-here

# 阿里云 DashScope（备用模型 + Embedding）
QWEN_API_KEY=sk-your-key-here
DASHSCOPE_API_KEY=sk-your-key-here

# LangSmith（可选，调试追踪用）
LANGCHAIN_API_KEY=lsv2_pt_your-key-here

# ── TTS 语音合成（CosyVoice v3.5-plus via DashScope API） ──
# 声音复刻后的 voice_id，运行 services/enroll_voice.py 自动生成
COSYVOICE_VOICE_ID=

# ── ASR 热词表 ID（DashScope 控制台创建，提升专有名词识别率） ──
ASR_PHRASE_ID=
